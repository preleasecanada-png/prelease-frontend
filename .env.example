# ============================================
# Prelease Canada — Frontend Environment Variables
# ============================================

# Backend API URL (AWS API Gateway endpoint)
NEXT_PUBLIC_BASE_API_HOST=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/production/api

# Image base URL (S3 bucket or API storage URL)
NEXT_PUBLIC_BASE_LOCAL_IMAGE_HOST=https://your-s3-bucket.s3.us-east-1.amazonaws.com

# Google OAuth (NEXT_PUBLIC_CLIENT_ID is used by _app.js GoogleOAuthProvider)
NEXT_PUBLIC_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Facebook OAuth
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Apple Sign In
NEXT_PUBLIC_APPLE_CLIENT_ID=your-apple-service-id

# Pusher (real-time chat)
NEXT_PUBLIC_PUSHER_APP_KEY=your-pusher-app-key
NEXT_PUBLIC_PUSHER_CLUSTER=mt1
NEXT_PUBLIC_PUSHER_APP_CLUSTER=mt1

# Stripe (client-side)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
